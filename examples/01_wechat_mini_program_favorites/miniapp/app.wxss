page { background: #f6f7f9; color: #1f2329; font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", Arial, sans-serif; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.04); }
.title { font-size: 36rpx; font-weight: 700; }
.subtitle { font-size: 28rpx; color: #646a73; line-height: 1.6; }
.primary-button { background: #1677ff; color: #fff; border-radius: 999rpx; font-size: 30rpx; padding: 18rpx 28rpx; text-align: center; }
.secondary-button { background: #eef4ff; color: #1677ff; border-radius: 999rpx; font-size: 30rpx; padding: 18rpx 28rpx; text-align: center; }
