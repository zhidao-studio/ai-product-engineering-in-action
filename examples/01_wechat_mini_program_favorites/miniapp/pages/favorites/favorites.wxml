<view class="container">
  <view class="card"><view class="title">我的收藏</view><view class="subtitle">这里展示本地保存的收藏地点。</view></view>
  <view wx:if="{{favorites.length === 0}}" class="card"><view class="title">暂无收藏</view><view class="subtitle">去首页选择一个地点收藏试试。</view></view>
  <view wx:else><view wx:for="{{favorites}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}"><view class="place-name">{{item.name}}</view><view class="subtitle">{{item.area}} · {{item.distance}}</view><view class="tag-text">{{item.tagText}}</view></view></view>
</view>
